# ============================================================================
#  Plantilla de variables de entorno - Plataforma de Cotizaciones y Pedidos
#  Copia este archivo como `.env.local` y rellena los valores reales.
#  NUNCA subas `.env.local` al repositorio (ya está en .gitignore).
#  Todo lo específico de la empresa vive AQUÍ, no en el código.
# ============================================================================

# ----------------------------------------------------------------------------
# Modo de datos y autenticación
#   demo     → datos en memoria + login por cookie (corre sin configurar nada).
#   supabase → Postgres/Supabase + Supabase Auth (correo y contraseña reales).
# ----------------------------------------------------------------------------
DATA_MODE="demo"                              # demo | supabase

# ----------------------------------------------------------------------------
# Supabase (base de datos + autenticación + tiempo real)
# Obtén estos valores en: Supabase Dashboard > Project Settings > API
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key-publica"
# Clave de servicio: SOLO se usa en el servidor. Da acceso total. Trátala como una contraseña.
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key-secreta"

# Administrador inicial que crea el seed (npm run seed:supabase).
# Con esta cuenta entras la primera vez y desde el panel admin creas al resto.
SEED_ADMIN_EMAIL="admin@tu-empresa.com"
SEED_ADMIN_PASSWORD="cambia-esta-clave"
SEED_ADMIN_NOMBRE="Administrador"

# ----------------------------------------------------------------------------
# World Office Cloud (integración API REAL - plan Enterprise)
# Durante el concurso se usa el cliente MOCK (WORLDOFFICE_MODE=mock).
# Para producción: WORLDOFFICE_MODE=live + los valores reales de la cuenta.
# El token se copia desde World Office: Configuración > General > API.
# Auth real: header  Authorization: WO <token>  (no es Bearer).
# ----------------------------------------------------------------------------
WORLDOFFICE_MODE="mock"                       # mock | live
WORLDOFFICE_API_BASE_URL="https://api.worldoffice.cloud/api/v1"
WORLDOFFICE_API_TOKEN="token-jwt-de-world-office"
WORLDOFFICE_EMPRESA_ID="EMPRESA-DEMO"         # etiqueta para el payload neutro (modo mock)

# IDs de configuración contable de la cuenta real (confirmar en World Office).
# documentoTipo se confirma con el servicio "listar tipos de documento".
WORLDOFFICE_ID_EMPRESA=""                      # idEmpresa (numérico)
WORLDOFFICE_ID_TERCERO_INTERNO=""             # responsable/vendedor en WO (numérico)
WORLDOFFICE_ID_FORMA_PAGO=""                  # idFormaPago (numérico)
WORLDOFFICE_ID_MONEDA=""                      # idMoneda (numérico, ej. COP)
WORLDOFFICE_ID_BODEGA=""                      # idBodega (numérico)
WORLDOFFICE_ID_CENTRO_COSTO=""                # idCentroCosto de los renglones (numérico)
WORLDOFFICE_PREFIJO=""                         # prefijo del consecutivo del documento (numérico)
WORLDOFFICE_TRM="1"                           # tasa de cambio; para COP es 1
WORLDOFFICE_DOCTIPO_FACTURA="FV"              # tipo documento factura de venta
WORLDOFFICE_DOCTIPO_PEDIDO="PD"               # tipo documento pedido (confirmar)

# Nombre del arreglo de líneas del documento. El swagger.json oficial define
# "renglones" (los ejemplos del portal muestran "reglones" con typo). Si al
# probar el documento entra SIN líneas, prueba con "reglones".
WORLDOFFICE_CAMPO_RENGLONES="renglones"

# Cruce fino pedido→factura: al facturar, consulta los renglones del pedido y
# envía idDetalles. Déjalo en "false" hasta confirmar la respuesta real de
# getRenglonesByDocumentoEncabezado contra la cuenta; luego ponlo en "true".
WORLDOFFICE_CRUZAR_DETALLES="false"

# Rutas de los servicios (déjalas vacías para usar las por defecto).
# Confirmar la integración real = cambiar AQUÍ, sin tocar el código.
# Defaults verificados en la spec real de World Office (base ya incluye /api/v1).
WORLDOFFICE_RUTA_CREAR_DOCUMENTO=""           # def: /documentos  (POST)
WORLDOFFICE_RUTA_EDITAR_DOCUMENTO=""          # def: /documentos/editarDocumentoEncabezado (PUT)
WORLDOFFICE_RUTA_INVENTARIOS=""               # def: /inventarios  (se consulta /inventarios/{codigo})
WORLDOFFICE_RUTA_CLASIFICACIONES=""           # def: /inventarios/clasificaciones (categorías)
WORLDOFFICE_RUTA_TERCEROS=""                  # def: /terceros/identificacion (se añade /{nit})

# Robustez de red (timeout y reintentos con backoff ante 5xx/429).
WORLDOFFICE_TIMEOUT_MS="15000"                # ms antes de abortar una petición
WORLDOFFICE_MAX_REINTENTOS="3"                # intentos ante errores transitorios

# ----------------------------------------------------------------------------
# Gmail API (notificación por correo al área contable)
# Configurado vía cuenta de servicio o OAuth2. Ver docs/INTEGRACION-WORLD-OFFICE.md
# ----------------------------------------------------------------------------
GMAIL_SENDER="notificaciones@tu-empresa.com"
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REFRESH_TOKEN=""
NOTIFICACIONES_CONTABLE_TO="contabilidad@tu-empresa.com"

# ----------------------------------------------------------------------------
# Aplicación (identidad/marca: cámbialo por empresa sin tocar el código)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Cotizaciones y Pedidos"
NEXT_PUBLIC_EMPRESA_NOMBRE="Tu Empresa S.A.S"
APP_BASE_URL="http://localhost:3000"
